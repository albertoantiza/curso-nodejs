{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "noEmitOnError": true,
    "sourceMap": true
  },
  "include": [
    "apirouter.ts",
    "notas.ts",
    "clase1/**/*.ts",
    "clase2/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
